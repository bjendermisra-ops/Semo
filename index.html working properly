        // --- Firebase Configuration ---
        const firebaseConfig = {
            apiKey: "AIzaSyAHksBlu9ue2p7AxXuUKALmEws5mscO908",
            authDomain: "iskcon-bhuvaikuntha.firebaseapp.com",
            projectId: "iskcon-bhuvaikuntha",
            storageBucket: "iskcon-bhuvaikuntha.firebasestorage.app",
            messagingSenderId: "87535383708",
            appId: "1:87535383708:web:7548e3b7d4c807faafe959",
            measurementId: "G-ZWEB9HM0K4"
        };

        // Initialize Firebase Client
        firebase.initializeApp(firebaseConfig);
        const db = firebase.firestore();

        let currentSeva = '';
        let selectedAmt = 500;
        let globalLiveDonations = [];

        // App lifecycle listeners
        window.addEventListener('DOMContentLoaded', () => {
            // Apply language setup instantly on load from shared localStorage [1.4]
            const savedLang = localStorage.getItem('lang') || 'en';
            setLanguage(savedLang);

            startLiveDonationsListener();
            
            // Auto Parameter deep linking filter trigger
            const urlParams = new URLSearchParams(window.location.search);
            const category = urlParams.get('category');
            if (category) {
                let tabName = decodeURIComponent(category);
                if (tabName === 'Gau Seva' || tabName === 'Gau' || tabName === 'Go seva') {
                    filterCategory('Gau Seva');
                } else if (tabName === 'Temple' || tabName === 'Temple Seva') {
                    filterCategory('Temple');
                } else if (tabName === 'Annadan' || tabName === 'Anna Dân Seva') {
                    filterCategory('Annadan');
                } else {
                    filterCategory('All');
                }
            }
        });

        // Multi-Page Real-time Live Storage Sync Engine
        window.addEventListener('storage', (event) => {
            if (event.key === 'lang') {
                const newLang = event.newValue || 'en';
                setLanguage(newLang);
            }
        });

        // --- Language Switcher Logic ---
        function setLanguage(lang) {
            localStorage.setItem('lang', lang);
            const texts = langData[lang];

            document.querySelectorAll('[data-key]').forEach(el => {
                const key = el.getAttribute('data-key');
                if (texts[key]) {
                    el.innerText = texts[key];
                }
            });

            // Update custom placeholders dynamically
            const customAmtInput = document.getElementById('custom-amount');
            if (customAmtInput && texts["modal_custom_placeholder"]) {
                customAmtInput.placeholder = texts["modal_custom_placeholder"];
            }

            // Update active Lang Chip layout
            document.querySelectorAll('.lang-chip').forEach(chip => {
                chip.classList.remove('active');
            });
            const activeChip = document.getElementById('chip-' + lang);
            if (activeChip) {
                activeChip.classList.add('active');
            }
        }

        // --- Real-time Firestore Listener ---
        function startLiveDonationsListener() {
            db.collection("donations")
              .orderBy("date", "desc")
              .limit(30)
              .onSnapshot((snapshot) => {
                  globalLiveDonations = [];
                  snapshot.forEach((doc) => {
                      const data = doc.data();
                      
                      let dateVal = '';
                      if (data.date) {
                          const tDate = data.date.toDate ? data.date.toDate() : new Date(data.date);
                          dateVal = tDate.toLocaleString('en-IN', {
                              timeZone: 'Asia/Kolkata',
                              day: '2-digit',
                              month: '2-digit',
                              year: 'numeric',
                              hour: '2-digit',
                              minute: '2-digit',
                              hour12: true
                          });
                      }

                      globalLiveDonations.push({
                          name: data.name || 'Anonymous Donor',
                          amount: data.amount || 0,
                          date: dateVal
                      });
                  });
              }, (error) => {
                  console.error("Firestore live update stream interrupted: ", error);
              });
        }

        function filterCategory(category) {
            // Tab Selection Highlights
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            if (category === 'All') document.getElementById('tab-all').classList.add('active');
            if (category === 'Gau Seva') document.getElementById('tab-gau').classList.add('active');
            if (category === 'Temple') document.getElementById('tab-temple').classList.add('active');
            if (category === 'Annadan') document.getElementById('tab-annadan').classList.add('active');

            const cards = document.querySelectorAll('.seva-card');
            cards.forEach(card => {
                if (category === 'All' || card.getAttribute('data-category') === category) {
                    card.classList.remove('hidden');
                } else {
                    card.classList.add('hidden');
                }
            });
        }

        function openAmountModal(sevaName) {
            currentSeva = sevaName;
            document.getElementById('selected-seva-title').innerText = sevaName;
            document.getElementById('step-amount').classList.remove('hidden');
            document.getElementById('step-form').classList.add('hidden');
            document.getElementById('payment-modal').classList.remove('hidden');
        }

        function closeModal(id) {
            document.getElementById(id).classList.add('hidden');
        }

        function selectAmount(amount, element) {
            document.querySelectorAll('.amt-btn').forEach(btn => btn.classList.remove('selected'));
            element.classList.add('selected');

            if (amount === 0) {
                document.getElementById('custom-amount').classList.remove('hidden');
                selectedAmt = 0;
            } else {
                document.getElementById('custom-amount').classList.add('hidden');
                selectedAmt = amount;
            }
        }

        function updateCustomAmount(val) {
            selectedAmt = Number(val);
        }

        function goToDonorInfo() {
            if (selectedAmt <= 0) {
                alert('Please enter or select a valid amount!');
                return;
            }
            document.getElementById('step-amount').classList.add('hidden');
            document.getElementById('step-form').classList.remove('hidden');
        }

        function backToAmount() {
            document.getElementById('step-form').classList.add('hidden');
            document.getElementById('step-amount').classList.remove('hidden');
        }

        // SECURE API HANDOFF TO VERCEL BACKEND
        async function generateSecurePaymentLink() {
            const name = document.getElementById('donor-name').value;
            const phone = document.getElementById('donor-phone').value;
            const email = document.getElementById('donor-email').value || '';

            if(!name || !phone) {
                alert('Please fill Name and Mobile Number!');
                return;
            }

            if (phone.length < 10) {
                alert('Please enter a valid 10-digit mobile number!');
                return;
            }

            const payBtn = document.querySelector('#step-form .donate-btn');
            payBtn.innerText = "Securing Connection...";
            payBtn.disabled = true;

            try {
                const response = await fetch('/api/create-link', { 
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        name: name,
                        amount: selectedAmt,
                        phone: phone,
                        email: email,
                        seva: currentSeva
                    })
                });

                const data = await response.json();
                
                if (data.payment_url) {
                    const a = document.createElement('a');
                    a.href = data.payment_url;
                    a.target = '_blank';
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    
                    closeModal('payment-modal');
                } else {
                    alert('Server Error: ' + (data.error || 'Unable to initiate payment gateway.'));
                }
            } catch (err) {
                console.error(err);
                alert('Secure Server Connection failed. Please check network and retry.');
            } finally {
                payBtn.innerText = "Proceed to Payment";
                payBtn.disabled = false;
            }
        }

        function openLiveDonationsModal() {
            const container = document.getElementById('live-donations-list');
            container.innerHTML = '';
            const lang = localStorage.getItem('lang') || 'en';

            if (globalLiveDonations.length === 0) {
                const noDonationText = langData[lang]["no_donations"] || "No donations yet!";
                container.innerHTML = `<div style="text-align:center; padding: 20px; color: #999;">${noDonationText}</div>`;
            } else {
                globalLiveDonations.forEach(item => {
                    const cleanName = escapeHtml(item.name);
                    const row = `
                        <div class="donation-item">
                            <div class="donor-details">
                                <div class="donor-name">${cleanName}</div>
                                <div class="donor-time">${item.date}</div>
                            </div>
                            <div class="donor-amt">₹${item.amount}</div>
                        </div>
                    `;
                    container.innerHTML += row;
                });
            }
            document.getElementById('live-modal').classList.remove('hidden');
        }

        // Helper to prevent dynamic string injections
        function escapeHtml(text) {
            if (!text) return '';
            return text
                .toString()
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }
    </script>
